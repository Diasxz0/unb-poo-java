package exer_Conta;

public class ContaPoupanca extends ContaBancaria{

		private double diaRendimento;

		public ContaPoupanca() {
			super();
		}

		public ContaPoupanca(double diaRendimento) {
			super();
			this.diaRendimento = diaRendimento;
		}
		
		
		
		public ContaPoupanca(String nomeConta, String numeroConta, double saldo, double diaRendimento) {
			super(nomeConta, numeroConta, saldo);
			this.diaRendimento = diaRendimento;
		}

		public void calcularNovoRendimento(double diaRedimento) {
			super.saldo *= (1 + (diaRendimento / 100));
			System.out.println("Rebdimento aplicado!");
			System.out.println("Atualizando saldo..");
			System.out.println("Novo saldo: " + super.saldo);
		}
		
		@Override
		public void realizarSaque(double valor) {
			
			if(	saldo < valor || saldo <= 0) {
				System.out.println("Saldo Insuficiente!");
				return;
			} 
			saldo -= valor;
			System.out.println("Saldo Atualizado!");
			return;
		}

		public String toString() {
			String s = "-----CONTA POUPANÇA----" + "\n";
			s += "Nome da conta: " + super.nomeConta + "\n";
			s += "Numero da conta: " + super.numeroConta + "\n";
			s += "Saldo " + super.saldo + " reais" + "\n";
			return s;
		}
		
		
}
