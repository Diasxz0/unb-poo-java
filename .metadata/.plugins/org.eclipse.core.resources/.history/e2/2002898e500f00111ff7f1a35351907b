package folha_Pagamento;

import java.util.Scanner;

public class Teste {

	public static void main(String[] args) throws SalarioInvalido {
		Scanner scan = new Scanner(System.in);
		
		
		
		FolhaPagamento folha = new FolhaPagamento();
		
		System.out.println("\n1 - Adicionar \n2 - Listar \n0- Sair");
		int escolha = scan.nextInt();
		scan.nextLine();
		boolean continuar = true;
		while(continuar) {
			switch(escolha) {
			case 1:
				
				String nome;
				double salario;
				int id;
				
				try {
					System.out.print("Nome: ");
					nome = scan.nextLine();
					
					System.out.print("Salario: ");
					salario = scan.nextDouble();
					
					if(salario < 0) {
						throw new SalarioInvalido();
					}

					
					System.out.print("ID: ");
					id = scan.nextInt();
					scan.nextLine();

				
					System.out.println("\n1 - Desenvolvedor \n2 - Gerente \n3 - Estagiario");
					int escolha_2 = scan.nextInt();
					switch(escolha_2) {
					case 1:

						System.out.print("linguagem: ");
						String linguagem = scan.nextLine();

						Desenvolvedor dev = new Desenvolvedor(nome, id, salario, linguagem);
						folha.adicionarFuncionario(dev);
						break;

					case 2:

						System.out.print("Bonificação Anual: ");
						double bonus = scan.nextDouble();

						Gerente gerente = new Gerente(nome, id, salario, bonus);
						folha.adicionarFuncionario(gerente);
						break;

					case 3:

						Estagiario estag = new Estagiario(nome, id, salario);
						folha.adicionarFuncionario(estag);
						break;
					}
				}
			} catch (SalarioInvalido e) {
				System.err.print(e.getMessage());
			} catch (Throwable e) {
				System.err.println("Erro na entrada de dados. Cadastro cancelado.");
				scan.nextLine();
			}
			case 2:
				folha.calcularTotalFolha();
				System.out.println("\n");
				folha.listarRelatorio();
				break;
			case 0:
				continuar = false;
				break;
			} 
		}

	}
}
