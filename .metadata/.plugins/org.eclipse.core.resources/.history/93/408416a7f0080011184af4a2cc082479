package exer_Conta;

public class ContaEspecial extends ContaBancaria {

		private double limite;

		public double getLimite() {
			return limite;
		}

		public void setLimite(double limite) {
			this.limite = limite;
		}
	
		public void realizarSaque(double valor) {
			
			if(valor > this.limite)
				return;
			
			
			super.saldo -= valor;
			
			if(super.saldo >= 0 && super.saldo >= valor) {
				System.out.println("Ainda restam " + super.saldo +" reais");
				return;
			}
			System.out.println("Você está devendo " + super.saldo + " reais");
			return;
		}
		
		public String toString() {
			String s = "-----CONTA ESPECIAL----" + "\n";
			s += "Nome da conta: " + super.nomeConta + "\n";
			s += "Numero da conta: " + super.numeroConta + "\n";
			s += "Saldo " + super.saldo + " reais" + "\n";
			s += "Limite: " + this.limite;
			return s;
		}
}
