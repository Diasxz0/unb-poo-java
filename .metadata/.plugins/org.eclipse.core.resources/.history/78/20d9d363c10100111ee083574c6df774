package Guanabara;

import java.util.Scanner;
import java.lang.Math;

public class Baskhara {
	public static void main(String[] agrs) {
		int a, b, c;
		
		Scanner scanner = new Scanner(System.in);
		
		System.out.printf("\n\tDigite o valor de A: ");
		a = scanner.nextInt();
		
		System.out.printf("\n\tDigite o valor de B: ");
		b = scanner.nextInt();
		
		System.out.printf("\n\tDigite o valor de C: ");
		c = scanner.nextInt();

		int delta = b*b - (4 * a * c);
		
		double raiz = Math.sqrt(delta);
		
		if(raiz > 0) {
			double resultado_1 = (-b + raiz) / (2*a);
			double resultado_2 = (-b - raiz) / (2*a);
			System.out.printf("\n\tOs resultados são: %f %f", resultado_1, resultado_2);
		} else if(raiz == 0) {
			double resultado_1 = (-b + raiz) / (2*a);
			System.out.printf("\n\tOs resultados são: %f %f", resultado_1);
		} else {
			System.out.printf("\n\tNao ha resultados reais");
		}
		
		scanner.close();
		
	}
}
