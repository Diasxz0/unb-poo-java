package exer_dimensao;

public abstract class Figura2D extends FiguraGeometrica implements DimensaoSuperficial{
	
	int lados;
	double altura;
	double largura;

	public double getAltura() {
		return altura;
	}

	public void setAltura(double altura) {
		this.altura = altura;
	}

	public double getLargura() {
		return largura;
	}
	

	public void setLargura(double largura) {
		this.largura = largura;
	}

	public int getLados() {
		return lados;
	}

	public Figura2D(String nome, String cor, double altura) {
		super();
		this.nome = nome;
		this.cor = cor;
		this.altura = altura;
		this.largura = altura;
	}

	public void setLados(int lados) {
		this.lados = lados;
	}

	
	@Override
	public String toString() {
		String s = "\nNome: " + super.nome;
		s += "\nCor: " + super.cor;
		s += "\nLados: " + this.lados;
		return s;
	}

	
}
