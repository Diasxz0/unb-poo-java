package Guanabara;

public class Vetor {
	public static void main(String[] agrs) {
		int vetor[] = {1, 2, 3, 4, 5};
		
		/* diferente forma de atribuir diferentes valores
		 a uma mesma variavel */
		
		for(int numero : vetor) {
			System.out.printf("%d ", numero); //printa os numeros no vetor
		}
	}
}
