package exer_tem_mtos;

public class Teste_casting {
	public static void main(String[] args) {
		
		Aluno aluno = new Aluno();
		Pessoa alunoPessoa = aluno; //upcasting 
		
		Pessoa aluno2 = (Pessoa) new Aluno(); //upcasting tambem, mas eh manual, nao necesssario
		
		Object obj1 = obterString();
		
		String s1 = (String) obj1; //downcasting pq retorna uma string
		
		Object obj2 = "Minha String"; //upcasting
		
		String s2 = (String) obj2; //downcasting
		
		Object obj3 = new Object();
		
		String s3 = (String) obj3; //da erro pq obj3 nao faz referencia a uma string
		
		Object obj4 = obterInteiro();
		String s4 = (String) obj4 //downcasting, mas da erro pq obj4 referencia Int, nao String 
		
		
	}

	
	public static String obterString() {
		return "minha string";
	}
	
	public static int obterInteiro() {
		return 1;
	}
	
	
	
}