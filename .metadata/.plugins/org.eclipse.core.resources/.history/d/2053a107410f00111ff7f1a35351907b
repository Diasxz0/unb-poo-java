package folha_Pagamento;

public class Desenvolvedor extends Funcionario{

	private String lingaugemPrincipal;

	public Desenvolvedor() {
		super();
		// TODO Auto-generated constructor stub
	}


	public Desenvolvedor(String nome, int id, double salarioBase) {
		super(nome, id, salarioBase);
		// TODO Auto-generated constructor stub
	}

	public Desenvolvedor(String lingaugemPrincipal) {
		super();
		this.lingaugemPrincipal = lingaugemPrincipal;
	}
	
	public String getLingaugemPrincipal() {
		return lingaugemPrincipal;
	}


	public void setLingaugemPrincipal(String lingaugemPrincipal) {
		this.lingaugemPrincipal = lingaugemPrincipal;
	}


	@Override
	public double calcularSalario() {
		return super.getSalarioBase() * 1.15;
	}
	
	
}
